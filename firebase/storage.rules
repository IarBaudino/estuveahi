rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{userId}/{file} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /photos-original/{photographerId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == photographerId;
    }
    match /photos-preview/{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
    match /photos-thumbnail/{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
