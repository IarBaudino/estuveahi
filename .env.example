# Firebase — auth y base de datos (Firestore)
# https://console.firebase.google.com
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# En Vercel: una sola línea, sin comillas, con \n literales entre líneas del PEM.
# Ej: -----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n
FIREBASE_PRIVATE_KEY=
# Alternativa más simple en Vercel: JSON completo del service account en una línea.
# FIREBASE_SERVICE_ACCOUNT_JSON=
NEXT_PUBLIC_FIREBASE_API_KEY=

# Supabase — solo Storage de imágenes (plan gratuito)
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth (obligatorio en producción — podés usar la misma clave en ambas)
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://www.estuveahi.com.ar

# App (usar siempre el dominio canónico con www)
NEXT_PUBLIC_APP_URL=https://www.estuveahi.com.ar

# Google Search Console — meta tag de verificación (opcional)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
