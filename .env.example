# Firebase — auth y base de datos (Firestore)
# https://console.firebase.google.com
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
NEXT_PUBLIC_FIREBASE_API_KEY=

# Supabase — solo Storage de imágenes (plan gratuito)
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth (obligatorio en producción — podés usar la misma clave en ambas)
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://estuveahi.com.ar

# App
NEXT_PUBLIC_APP_URL=https://estuveahi.com.ar

# OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
